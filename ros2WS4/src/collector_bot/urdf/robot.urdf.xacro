<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="collector_bot">

  <!-- ═══════════════════ ARGUMENTS ═══════════════════ -->
  <xacro:arg name="robot_ns" default="robot_1"/>
  <xacro:property name="ns" value="$(arg robot_ns)"/>

  <!-- ═══════════════════ DIMENSIONS ═══════════════════ -->
  <xacro:property name="chassis_x" value="0.35"/>
  <xacro:property name="chassis_y" value="0.35"/>
  <xacro:property name="chassis_h" value="0.08"/>
  <xacro:property name="chassis_m" value="3.0"/>
  <xacro:property name="chassis_z" value="0.065"/>

  <xacro:property name="caster_r" value="0.025"/>
  <xacro:property name="caster_m" value="0.05"/>
  <xacro:property name="caster_xy" value="0.12"/>

  <!-- ═══════════════════ MATERIALS ═══════════════════ -->
  <material name="body">  <color rgba="0.25 0.25 0.30 1"/></material>
  <material name="accent"><color rgba="0.1 0.6 0.9 1"/></material>
  <material name="dark">  <color rgba="0.2 0.2 0.2 1"/></material>
  <material name="red">   <color rgba="0.8 0.1 0.1 1"/></material>
  <material name="green"> <color rgba="0.1 0.8 0.1 1"/></material>

  <!-- ═══════════════════ INERTIA MACROS ═══════════════════ -->
  <xacro:macro name="box_inertia" params="m x y z">
    <inertial><mass value="${m}"/>
      <inertia ixx="${m/12*(y*y+z*z)}" ixy="0" ixz="0"
               iyy="${m/12*(x*x+z*z)}" iyz="0"
               izz="${m/12*(x*x+y*y)}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="sphere_inertia" params="m r">
    <inertial><mass value="${m}"/>
      <inertia ixx="${2*m*r*r/5}" ixy="0" ixz="0"
               iyy="${2*m*r*r/5}" iyz="0"
               izz="${2*m*r*r/5}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="cyl_inertia" params="m r h">
    <inertial><mass value="${m}"/>
      <inertia ixx="${m/12*(3*r*r+h*h)}" ixy="0" ixz="0"
               iyy="${m/12*(3*r*r+h*h)}" iyz="0"
               izz="${m*r*r/2}"/>
    </inertial>
  </xacro:macro>

  <!-- ═══════════════════ BASE ═══════════════════ -->
  <link name="base_footprint"/>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${chassis_z}" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <geometry><box size="${chassis_x} ${chassis_y} ${chassis_h}"/></geometry>
      <material name="body"/>
    </visual>
    <collision>
      <geometry><box size="${chassis_x} ${chassis_y} ${chassis_h}"/></geometry>
    </collision>
    <xacro:box_inertia m="${chassis_m}" x="${chassis_x}" y="${chassis_y}" z="${chassis_h}"/>
  </link>
  <gazebo reference="base_link"><material>Gazebo/DarkGrey</material></gazebo>

  <!-- ═══════════════════ 4 × CASTERS ═══════════════════ -->
  <xacro:macro name="caster" params="name cx cy">
    <link name="${name}">
      <visual><geometry><sphere radius="${caster_r}"/></geometry><material name="dark"/></visual>
      <collision><geometry><sphere radius="${caster_r}"/></geometry></collision>
      <xacro:sphere_inertia m="${caster_m}" r="${caster_r}"/>
    </link>
    <joint name="${name}_joint" type="fixed">
      <parent link="base_link"/>
      <child link="${name}"/>
      <origin xyz="${cx} ${cy} ${-(chassis_z - caster_r)}" rpy="0 0 0"/>
    </joint>
    <gazebo reference="${name}">
      <material>Gazebo/DarkGrey</material>
      <mu1>0.0</mu1><mu2>0.0</mu2>
    </gazebo>
  </xacro:macro>

  <xacro:caster name="caster_fl" cx="${ caster_xy}" cy="${ caster_xy}"/>
  <xacro:caster name="caster_fr" cx="${ caster_xy}" cy="${-caster_xy}"/>
  <xacro:caster name="caster_rl" cx="${-caster_xy}" cy="${ caster_xy}"/>
  <xacro:caster name="caster_rr" cx="${-caster_xy}" cy="${-caster_xy}"/>

  <!-- ═══════════════════ LIDAR ═══════════════════ -->
  <link name="lidar_link">
    <visual><geometry><cylinder radius="0.035" length="0.025"/></geometry>
      <material name="red"/></visual>
    <collision><geometry><cylinder radius="0.035" length="0.025"/></geometry></collision>
    <xacro:cyl_inertia m="0.05" r="0.035" h="0.025"/>
  </link>
  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0 0 ${chassis_h/2 + 0.015}" rpy="0 0 0"/>
  </joint>

  <gazebo reference="lidar_link">
    <material>Gazebo/Red</material>
    <sensor type="ray" name="lidar">
      <pose>0 0 0 0 0 0</pose>
      <visualize>false</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan><horizontal>
          <samples>360</samples><resolution>1</resolution>
          <min_angle>-3.14159</min_angle><max_angle>3.14159</max_angle>
        </horizontal></scan>
        <range><min>0.12</min><max>5.0</max><resolution>0.01</resolution></range>
        <noise><type>gaussian</type><mean>0</mean><stddev>0.008</stddev></noise>
      </ray>
      <plugin name="lidar_plugin" filename="libgazebo_ros_ray_sensor.so">
        <ros><namespace>${ns}</namespace>
          <remapping>~/out:=scan</remapping></ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>${ns}/lidar_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <!-- ═══════════════════ CAMERA ═══════════════════ -->
  <link name="camera_link">
    <visual><geometry><box size="0.02 0.06 0.025"/></geometry>
      <material name="green"/></visual>
    <collision><geometry><box size="0.02 0.06 0.025"/></geometry></collision>
    <xacro:box_inertia m="0.03" x="0.02" y="0.06" z="0.025"/>
  </link>
  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="${chassis_x/2} 0 ${chassis_h/4}" rpy="0 0.18 0"/>
  </joint>

  <link name="camera_optical_link"/>
  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_optical_link"/>
    <origin xyz="0 0 0" rpy="${-pi/2} 0 ${-pi/2}"/>
  </joint>

  <gazebo reference="camera_link">
    <material>Gazebo/Green</material>
    <sensor type="camera" name="rgb_camera">
      <update_rate>10</update_rate>
      <camera name="camera">
        <horizontal_fov>1.2</horizontal_fov>
        <image><width>640</width><height>480</height><format>R8G8B8</format></image>
        <clip><near>0.05</near><far>8.0</far></clip>
        <noise><type>gaussian</type><mean>0</mean><stddev>0.005</stddev></noise>
      </camera>
      <plugin name="camera_plugin" filename="libgazebo_ros_camera.so">
        <ros><namespace>${ns}</namespace></ros>
        <camera_name>camera</camera_name>
        <frame_name>${ns}/camera_optical_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <!-- ═══════════════════ IMU ═══════════════════ -->
  <link name="imu_link">
    <visual><geometry><box size="0.02 0.02 0.01"/></geometry>
      <material name="accent"/></visual>
    <xacro:box_inertia m="0.01" x="0.02" y="0.02" z="0.01"/>
  </link>
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <gazebo reference="imu_link">
    <sensor type="imu" name="imu_sensor">
      <update_rate>50</update_rate>
      <plugin name="imu_plugin" filename="libgazebo_ros_imu_sensor.so">
        <ros><namespace>${ns}</namespace>
          <remapping>~/out:=imu</remapping></ros>
        <frame_name>${ns}/imu_link</frame_name>
        <initial_orientation_as_reference>false</initial_orientation_as_reference>
      </plugin>
    </sensor>
  </gazebo>

  <!-- ═══════════════════ PLANAR MOVE (omni-drive) ═══════════════════ -->
  <gazebo>
    <plugin name="planar_move" filename="libgazebo_ros_planar_move.so">
      <ros><namespace>${ns}</namespace></ros>
      <command_topic>cmd_vel</command_topic>
      <odometry_topic>odom</odometry_topic>
      <odometry_frame>${ns}/odom</odometry_frame>
      <robot_base_frame>${ns}/base_footprint</robot_base_frame>
      <odometry_rate>30.0</odometry_rate>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
    </plugin>
  </gazebo>

</robot>
