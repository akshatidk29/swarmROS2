    <!-- ==================== BLUE SPHERES (r=0.10) ==================== -->
    <model name="sphere_1"><static>true</static>
      <link name="link">
        <collision name="c"><geometry><sphere><radius>0.10</radius></sphere></geometry></collision>
        <visual name="v"><geometry><sphere><radius>0.10</radius></sphere></geometry>
