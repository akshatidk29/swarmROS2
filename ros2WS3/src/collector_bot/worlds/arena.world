      <pose>-2.0 3.0 0.10 0 0 0</pose>
    </model>
    <model name="sphere_2"><static>true</static>
      <link name="link">
        <collision name="c"><geometry><sphere><radius>0.10</radius></sphere></geometry></collision>
        <visual name="v"><geometry><sphere><radius>0.10</radius></sphere></geometry>
          <material><ambient>0.0 0.0 0.9 1</ambient><diffuse>0.0 0.0 1.0 1</diffuse></material>
        </visual>
      </link>
      <pose>1.0 -1.5 0.10 0 0 0</pose>
    </model>
    <model name="sphere_3"><static>true</static>
      <link name="link">
        <collision name="c"><geometry><sphere><radius>0.10</radius></sphere></geometry></collision>
        <visual name="v"><geometry><sphere><radius>0.10</radius></sphere></geometry>
          <material><ambient>0.0 0.0 0.9 1</ambient><diffuse>0.0 0.0 1.0 1</diffuse></material>
        </visual>
      </link>
      <pose>-4.0 -1.0 0.10 0 0 0</pose>
    </model>
    <model name="sphere_4"><static>true</static>
      <link name="link">
        <collision name="c"><geometry><sphere><radius>0.10</radius></sphere></geometry></collision>
        <visual name="v"><geometry><sphere><radius>0.10</radius></sphere></geometry>
          <material><ambient>0.0 0.0 0.9 1</ambient><diffuse>0.0 0.0 1.0 1</diffuse></material>
        </visual>
      </link>
      <pose>3.5 1.0 0.10 0 0 0</pose>
    </model>
    <model name="sphere_5"><static>true</static>
      <link name="link">
        <collision name="c"><geometry><sphere><radius>0.10</radius></sphere></geometry></collision>
        <visual name="v"><geometry><sphere><radius>0.10</radius></sphere></geometry>
          <material><ambient>0.0 0.0 0.9 1</ambient><diffuse>0.0 0.0 1.0 1</diffuse></material>
        </visual>
      </link>
      <pose>-0.5 4.0 0.10 0 0 0</pose>
    </model>

    <!-- ==================== BASKET MARKERS ==================== -->
    <!-- Cube basket (GREEN pole) at (5, 5) -->
    <model name="basket_cube_marker"><static>true</static>
      <link name="link">
        <collision name="c"><geometry><cylinder><radius>0.15</radius><length>0.6</length></cylinder></geometry></collision>
        <visual name="v"><geometry><cylinder><radius>0.15</radius><length>0.6</length></cylinder></geometry>
          <material><ambient>0.0 0.8 0.0 1</ambient><diffuse>0.1 1.0 0.1 1</diffuse></material>
        </visual>
      </link>
      <pose>5 5 0.3 0 0 0</pose>
    </model>
    <!-- Cube basket floor patch -->
    <model name="basket_cube_floor"><static>true</static>
      <link name="link">
        <visual name="v"><geometry><box><size>1.2 1.2 0.005</size></box></geometry>
          <material><ambient>0.0 0.5 0.0 1</ambient><diffuse>0.1 0.6 0.1 1</diffuse></material>
        </visual>
      </link>
      <pose>5 5 0.003 0 0 0</pose>
    </model>

    <!-- Sphere basket (YELLOW pole) at (-5, 5) -->
    <model name="basket_sphere_marker"><static>true</static>
      <link name="link">
        <collision name="c"><geometry><cylinder><radius>0.15</radius><length>0.6</length></cylinder></geometry></collision>
        <visual name="v"><geometry><cylinder><radius>0.15</radius><length>0.6</length></cylinder></geometry>
          <material><ambient>0.9 0.9 0.0 1</ambient><diffuse>1.0 1.0 0.1 1</diffuse></material>
        </visual>
      </link>
      <pose>-5 5 0.3 0 0 0</pose>
    </model>
    <!-- Sphere basket floor patch -->
    <model name="basket_sphere_floor"><static>true</static>
      <link name="link">
        <visual name="v"><geometry><box><size>1.2 1.2 0.005</size></box></geometry>
          <material><ambient>0.6 0.6 0.0 1</ambient><diffuse>0.7 0.7 0.1 1</diffuse></material>
