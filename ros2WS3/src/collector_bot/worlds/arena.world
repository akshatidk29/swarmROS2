<?xml version="1.0" ?>
<sdf version="1.6">
  <world name="arena">

    <include><uri>model://ground_plane</uri></include>
    <include><uri>model://sun</uri></include>

    <physics type="ode">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1</real_time_factor>
      <real_time_update_rate>1000</real_time_update_rate>
    </physics>

    <!-- ==================== BOUNDARY WALLS (12x12) ==================== -->
    <model name="wall_north"><static>true</static>
      <link name="link">
        <collision name="c"><geometry><box><size>12.6 0.3 0.8</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>12.6 0.3 0.8</size></box></geometry>
          <material><ambient>0.5 0.5 0.5 1</ambient><diffuse>0.7 0.7 0.7 1</diffuse></material>
        </visual>
      </link>
      <pose>0 6 0.4 0 0 0</pose>
    </model>
    <model name="wall_south"><static>true</static>
      <link name="link">
        <collision name="c"><geometry><box><size>12.6 0.3 0.8</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>12.6 0.3 0.8</size></box></geometry>
          <material><ambient>0.5 0.5 0.5 1</ambient><diffuse>0.7 0.7 0.7 1</diffuse></material>
        </visual>
      </link>
      <pose>0 -6 0.4 0 0 0</pose>
    </model>
    <model name="wall_east"><static>true</static>
      <link name="link">
        <collision name="c"><geometry><box><size>0.3 12.6 0.8</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>0.3 12.6 0.8</size></box></geometry>
          <material><ambient>0.5 0.5 0.5 1</ambient><diffuse>0.7 0.7 0.7 1</diffuse></material>
        </visual>
      </link>
      <pose>6 0 0.4 0 0 0</pose>
    </model>
    <model name="wall_west"><static>true</static>
      <link name="link">
        <collision name="c"><geometry><box><size>0.3 12.6 0.8</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>0.3 12.6 0.8</size></box></geometry>
          <material><ambient>0.5 0.5 0.5 1</ambient><diffuse>0.7 0.7 0.7 1</diffuse></material>
        </visual>
      </link>
      <pose>-6 0 0.4 0 0 0</pose>
    </model>

    <!-- ==================== OBSTACLES ==================== -->
    <model name="obs_box_1"><static>true</static>
      <link name="link">
        <collision name="c"><geometry><box><size>1.5 0.3 0.5</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>1.5 0.3 0.5</size></box></geometry>
          <material><ambient>0.6 0.4 0.2 1</ambient><diffuse>0.7 0.5 0.3 1</diffuse></material>
        </visual>
      </link>
      <pose>3 0 0.25 0 0 0</pose>
    </model>

    <model name="obs_cyl_1"><static>true</static>
      <link name="link">
        <collision name="c"><geometry><cylinder><radius>0.4</radius><length>0.5</length></cylinder></geometry></collision>
        <visual name="v"><geometry><cylinder><radius>0.4</radius><length>0.5</length></cylinder></geometry>
          <material><ambient>0.4 0.4 0.2 1</ambient><diffuse>0.5 0.5 0.3 1</diffuse></material>
        </visual>
      </link>
      <pose>-2 -2 0.25 0 0 0</pose>
    </model>

    <model name="obs_box_2"><static>true</static>
      <link name="link">
        <collision name="c"><geometry><box><size>0.3 2.0 0.5</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>0.3 2.0 0.5</size></box></geometry>
          <material><ambient>0.6 0.4 0.2 1</ambient><diffuse>0.7 0.5 0.3 1</diffuse></material>
        </visual>
